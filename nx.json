{
  "pluginsConfig": {
    "@nrwl/js": {
      "analyzeSourceFiles": false
    }
  },
  "extends": "nx/presets/npm.json",
  "nxCloudAccessToken": "YzlhNWQwNDItNTAzOC00YWEzLTlkZWEtN2M2MzRjNmM4NWFifHJlYWQ=",
  "targetDefaults": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["{projectRoot}/dist"],
      "cache": true
    },
    "prebuild": {
      "dependsOn": ["^prebuild"],
      "cache": true
    },
    "test": {
      "dependsOn": ["^test"],
      "cache": true
    },
    "lint": {
      "dependsOn": ["^lint"],
      "cache": true
    },
    "prepublishOnly": {
      "dependsOn": ["build"]
    }
  },
  "targetDependencies": {
    "build": [
      {
        "target": "build",
        "projects": "dependencies"
      }
    ],
    "prepare": [
      {
        "target": "prepare",
        "projects": "dependencies"
      }
    ],
    "package": [
      {
        "target": "package",
        "projects": "dependencies"
      }
    ]
  },
  "affected": {
    "defaultBase": "master"
  },
  "tasksRunnerOptions": {
    "local": {
      "runner": "nx/tasks-runners/default"
    },
    "default": {
      "runner": "nx-cloud"
    }
  },
  "analytics": true,
  "release": {
    "projectsRelationship": "independent",
    "projects": ["packages/*", "!@react95/explorer"],
    "version": {
      "conventionalCommits": true,
      "ignorePatternsWhenDeterminingVersion": [
        "**/*.test.tsx",
        "**/*.md",
        "**/*.json",
        "**/*.stories.*",
        "**/.storybook/**"
      ]
    },
    "changelog": {
      "workspaceChangelog": false,
      "projectChangelogs": {
        "createRelease": "github",
        "entryWhenNoChanges": false,
        "renderOptions": {
          "applyUsernameToAuthors": true
        }
      }
    },
    "git": {
      "commit": true,
      "commitMessage": "chore(release): publish :floppy_disk: :tada: [skip ci]",
      "tag": true
    }
  }
}
